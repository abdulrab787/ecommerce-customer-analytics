{
  "name": "Ecommerce Analytics Pro Theme",
  "dataColors": [
    "#005B96",
    "#008C9E",
    "#00A8A8",
    "#F28C28",
    "#D9534F",
    "#7F8C8D",
    "#2ECC71",
    "#9B59B6"
  ],
  "background": "#FFFFFF",
  "foreground": "#1C1C1C",
  "tableAccent": "#008C9E",

  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "fontSize": 14,
            "color": { "solid": { "color": "#1C1C1C" } }
          }
        ],
        "labels": [
          {
            "fontSize": 12,
            "color": { "solid": { "color": "#333333" } }
          }
        ]
      }
    },

    "card": {
      "*": {
        "title": [
          {
            "fontSize": 12,
            "color": { "solid": { "color": "#4A4A4A" } }
          }
        ],
        "labels": [
          {
            "fontSize": 20,
            "color": { "solid": { "color": "#005B96" } }
          }
        ]
      }
    },

    "slicer": {
      "*": {
        "title": [
          {
            "fontSize": 12,
            "color": { "solid": { "color": "#1C1C1C" } }
          }
        ],
        "header": [
          {
            "fontSize": 12,
            "color": { "solid": { "color": "#333333" } }
          }
        ]
      }
    },

    "matrix": {
      "*": {
        "grid": [
          {
            "outlineColor": "#E0E0E0",
            "outlineWeight": 1
          }
        ],
        "columnHeaders": [
          {
            "fontSize": 12,
            "color": { "solid": { "color": "#1C1C1C" } },
            "backColor": { "solid": { "color": "#F5F7FA" } }
          }
        ],
        "values": [
          {
            "fontSize": 11,
            "color": { "solid": { "color": "#333333" } }
          }
        ]
      }
    }
  },

  "textClasses": {
    "title": {
      "fontSize": 14,
      "color": "#1C1C1C"
    },
    "header": {
      "fontSize": 12,
      "color": "#333333"
    },
    "callout": {
      "fontSize": 20,
      "color": "#005B96"
    }
  }
}
